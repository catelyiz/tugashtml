/* Reset dasar untuk margin dan padding */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f6f9;
    color: #333;
    /* Flexbox untuk menengahkan konten di layar */
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh; 
}

.container {
    padding: 20px;
    width: 100%;
    display: flex;
    justify-content: center;
}

/* Styling utama untuk Card */
.card {
    background-color: #ffffff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    max-width: 550px;
    width: 100%;
}

.card-center {
    text-align: center;
}

/* =========================================
   Styling Khusus index.html
   ========================================= */
.subtitle {
    color: #5c6bc0;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    margin-bottom: 15px;
}

h1 {
    color: #0b132b;
    font-size: 1.8rem;
    margin-bottom: 20px;
}

.description {
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 30px;
    font-size: 0.95rem;
}

.btn {
    display: inline-block;
    background-color: #111827;
    color: #ffffff;
    padding: 12px 30px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
}

.btn:hover {
    background-color: #1f2937;
}

/* =========================================
   Styling Khusus list-materi.html
   ========================================= */
.text-center {
    text-align: center;
}

h2 {
    color: #111827;
    margin-bottom: 30px;
    font-size: 1.4rem;
}

.section {
    margin-bottom: 25px;
}

.section-title {
    color: #6a67ce;
    font-size: 1.05rem;
    padding-bottom: 10px;
    border-bottom: 2px solid #e2e8f0;
    margin-bottom: 15px;
}

/* Styling untuk list (ul dan ol) */
ul, ol {
    padding-left: 20px;
    color: #475569;
    line-height: 1.8;
    font-size: 0.95rem;
}

ul {
    list-style-type: square; /* Membuat bullet berbentuk kotak */
}
